{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "admin.ironwoodintelligence.com" }],
      "destination": "/admin"
    },
    { "source": "/admin/:path*",    "destination": "/admin" },
    { "source": "/dashboard/:page", "destination": "/dashboard" },
    { "source": "/en",              "destination": "/" },
    { "source": "/en/:path*",       "destination": "/" },
    { "source": "/fr",              "destination": "/" },
    { "source": "/fr/:path*",       "destination": "/" }
  ]
}
